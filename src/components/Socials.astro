---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";
---

<div class="flex flex-wrap items-center gap-1">
  {
    SOCIALS.map(social => (
      <LinkButton
        href={social.href}
        class="rounded-full border border-border px-3 py-2 text-sm hover:border-accent sm:px-3 sm:py-2"
        title={social.linkTitle}
      >
        <social.icon class="inline-block size-4 fill-transparent stroke-current stroke-2" />
        <span>{social.name}</span>
      </LinkButton>
    ))
  }
</div>
