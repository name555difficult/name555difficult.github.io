---
import type { BlogPost } from "@/lib/content";
import { getBlogPath, getTopLevelTaxonomy } from "@/lib/content";
import Datetime from "./Datetime.astro";
import TaxonomyChip from "./TaxonomyChip.astro";

type Props = {
  post: BlogPost;
  compact?: boolean;
};

const { post, compact = false } = Astro.props;
const topLevelTaxonomies = getTopLevelTaxonomy(post);
const primaryTaxonomy = post.data.taxonomy[0];
---

<li
  data-blog-card
  data-top-levels={topLevelTaxonomies.join(",")}
  class="h-full"
>
  <article
    class:list={[
      "flex h-full flex-col gap-4 surface-panel-strong px-5 py-5 transition-transform duration-200 hover:-translate-y-1 sm:px-6",
      { "gap-3 px-4 py-4 sm:px-5": compact },
    ]}
  >
    <div class="flex items-start justify-between gap-4">
      <div class="section-label">
        {topLevelTaxonomies.join(" · ") || "Research"}
      </div>
      {
        post.data.featured && (
          <span class="rounded-full bg-accent-soft px-3 py-1 text-xs font-medium text-accent">
            Featured
          </span>
        )
      }
    </div>

    <div class="space-y-3">
      <a
        href={getBlogPath(post)}
        class="inline-block text-2xl leading-tight font-semibold tracking-tight hover:text-accent"
      >
        {post.data.title}
      </a>
      <Datetime pubDatetime={post.data.date} />
      <p class="text-sm leading-7 text-foreground/72 sm:text-base">
        {post.data.summary}
      </p>
    </div>

    <div class="mt-auto flex flex-wrap gap-2">
      {
        post.data.taxonomy.map(path => (
          <TaxonomyChip
            path={path}
            size="sm"
            href={`/architecture?focus=${encodeURIComponent(path)}`}
          />
        ))
      }
    </div>

    <div class="flex flex-wrap gap-4 text-sm">
      <a href={getBlogPath(post)} class="font-medium text-accent">
        Read article
      </a>
      {
        primaryTaxonomy && (
          <a
            href={`/architecture?focus=${encodeURIComponent(primaryTaxonomy)}`}
            class="text-foreground/65"
          >
            View topic
          </a>
        )
      }
    </div>
  </article>
</li>
