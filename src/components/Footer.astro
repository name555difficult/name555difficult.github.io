---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { SITE } from "@/config";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "mt-12 flex flex-col gap-4 surface-panel px-5 py-5 sm:mt-16 sm:flex-row sm:items-center sm:justify-between sm:px-6",
    ]}
  >
    <Socials />
    <div class="space-y-1 text-sm text-foreground/65">
      <div>Copyright &#169; {currentYear} {SITE.author}</div>
      <div>Built with Astro, GitHub Pages, PDF.js, and D3.</div>
    </div>
  </div>
</footer>
