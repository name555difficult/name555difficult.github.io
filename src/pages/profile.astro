---
import ProfileLayout from "@/layouts/ProfileLayout.astro";
import ProfilePageContent from "@/components/ProfilePageContent.astro";
import { getFeaturedPosts, getPublishedPosts } from "@/lib/content";
import { buildTaxonomyTree, countTaxonomyLeaves } from "@/lib/taxonomy";

const posts = await getPublishedPosts();
const featuredPosts = getFeaturedPosts(posts).slice(0, 4);
const taxonomyTree = buildTaxonomyTree(posts);
const taxonomyLeafCount = countTaxonomyLeaves(taxonomyTree);
---

<ProfileLayout
  title="Profile | Wang Zhengbao"
  description="A markdown-first profile page for research notes, architecture maps, and long-form technical writing."
>
  <ProfilePageContent
    featuredPosts={featuredPosts}
    postCount={posts.length}
    taxonomyLeafCount={taxonomyLeafCount}
  />
</ProfileLayout>
